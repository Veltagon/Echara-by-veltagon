# ECHARA provider credentials — copy to .env and fill in. .env is gitignored.
# Comma-separated <NAME>S lists are for future key rotation (M3); the harness
# currently uses the first key. Liveness as of 2026-07-01: only Cerebras works.

# ── Cerebras (LIVE) ─────────────────────────────────────────
# Reach it via the openai SDK, NOT raw urllib (Cloudflare 403s the urllib
# User-Agent as error 1010). Live models: gemma-4-31b, gpt-oss-120b, zai-glm-4.7.
# Only gemma-4-31b emits real tool_calls — that's the harness default
# (providers/__init__.py::HARNESS_PROVIDERS). There is NO qwen model anymore.
CEREBRAS_API_KEY=csk-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
CEREBRAS_API_KEYS=csk-key1,csk-key2

# ── Other providers (currently DOWN — see M2_5_OPENCODE_MAP.md) ──
# z.ai (429 no balance), Vercel gateway (needs card), Hugging Face (402),
# api.airforce (Cloudflare block). Add keys here when funded.
ZAI_API_KEYS=
HUGGINGFACE_TOKEN=
AIRFORCE_API_KEYS=
VERCEL_GATEWAY_API_KEYS=
